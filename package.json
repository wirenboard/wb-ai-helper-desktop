{
  "name": "wb-ai-helper-desktop",
  "version": "0.13.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun --hot src/server/index.ts",
    "dev:web": "vite",
    "build:web": "vue-tsc --noEmit -p tsconfig.web.json && vite build",
    "build": "bun scripts/build.ts",
    "smoke": "bun scripts/smoke.ts",
    "appimage": "bun scripts/build-appimage.ts",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.web.json",
    "test": "bun test tests/",
    "test:unit": "bun test tests/ --timeout 10000",
    "test:api": "bun test tests/api.test.ts --timeout 30000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.94.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "bonjour-service": "^1.3.0",
    "highlight.js": "11.11.1",
    "hono": "^4.6.14",
    "internmap": "2.0.3",
    "jszip": "3.10.1",
    "marked": "18.0.3",
    "mermaid": "11.14.0",
    "mqtt": "^5.10.1",
    "openai": "^4.78.0",
    "ssh2": "1.17.0",
    "tar-stream": "3.2.0",
    "vega": "6.2.0",
    "vega-lite": "6.4.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "@types/ssh2": "1.15.5",
    "@types/tar-stream": "3.1.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
